<!-- Gnome Theme -->
<Styles xmlns="https://github.com/avaloniaui">
    <!-- BASE BUTTON STYLE (Applies to all buttons) -->
    <Style Selector="Button">
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="FontWeight" Value="600"/>  
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="FontSize" Value="{DynamicResource BaseFontSize}" />
        <Setter Property="BorderThickness" Value="2"/>  
        <Setter Property="BorderBrush" Value="Transparent"/>  
    </Style>
    
    <Style Selector="Button:not(.btnIcon)">
        <Setter Property="MinWidth" Value="120"/>
        <Setter Property="Margin" Value="4"/>  
    </Style>
    <Style Selector="Button.btnIcon">
        <Setter Property="MinWidth" Value="50"/>  
    </Style>

    <!-- DEFAULT BUTTON (SECONDARY) -->
    <Style Selector="Button:not(.primary2)">
        <Setter Property="Background" Value="{DynamicResource DefaultButtonBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource DefaultButtonForeground}" />
    </Style>
    <Style Selector="Button:focus">
        <Setter Property="Background" Value="{DynamicResource SystemAccentBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}" />
    </Style>

    <!-- <Style Selector="Button:not(.primary2):hover"> -->
    <!--     <Setter Property="Background" Value="{DynamicResource DefaultButtonHover}" /> -->
    <!-- </Style> -->
    <!-- -->
    <!-- <Style Selector="Button:not(.primary2):pressed"> -->
    <!--     <Setter Property="Background" Value="{DynamicResource DefaultButtonPressed}" /> -->
    <!-- </Style> -->

    <!-- PRIMARY BUTTON (ACCENT) -->
    <!-- <Style Selector="Button.primary2"> -->
    <!--     <Setter Property="Background" Value="{DynamicResource SystemAccentColor}" />  -->
    <!--     <Setter Property="Foreground" Value="White"/> -->
    <!-- </Style> -->
    <!-- -->
    <!-- <Style Selector="Button.primary2:hover"> -->
    <!--     <Setter Property="Background" Value="{DynamicResource SystemAccentColor}" /> -->
    <!-- </Style> -->
    <!-- -->
    <!-- <Style Selector="Button.primary2:pressed"> -->
    <!--     <Setter Property="Background" Value="{DynamicResource SystemAccentColor}" /> -->
    <!-- </Style> -->
    
    <!-- Textbox -->
    <Style Selector="TextBox">
        <Setter Property="Background" Value="{DynamicResource TextBoxBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBoxForeground}" />
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="8,8"/>
        <Setter Property="FontSize" Value="{DynamicResource BaseFontSize}" />
        <Setter Property="BorderThickness" Value="2"/>  <!-- No border by default -->
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>


    <!-- Disabled TextBox -->
    <Style Selector="TextBox:disabled">
        <Setter Property="Background" Value="{DynamicResource DisabledBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource DisabledForeground}" />
    </Style>
    
    <Style Selector="Button.btnIcon">
        <Setter Property="Background" Value="{DynamicResource DisabledBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource DisabledForeground}" />
    </Style>

    <!-- Focused TextBox (GNOME uses accent color for focus) -->
    <Style Selector="TextBox:focus /template/ Border">
        <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}"/>
    </Style>

    
    <!-- Textbox -->

    
    <!-- GNOME-SPECIFIC WINDOW STYLE -->
    <Style Selector="Window.messagebox" >
        <Setter Property="SystemDecorations" Value="None" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="SizeToContent" Value="Height" />
        <Setter Property="MinWidth" Value="400" />
    </Style>
    <Style Selector="StackPanel.mbOuter">
        <Setter Property="Spacing" Value="10" />
    </Style>
    <Style Selector="StackPanel.mbContent TextBlock">
        <Setter Property="TextAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.mbTitle">
        <Setter Property="FontSize" Value="{DynamicResource LargeFontSize}" />
        <Setter Property="Margin" Value="0 0 0 14" />
    </Style>
    <Style Selector="StackPanel.modalButtons">
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>
    
    
    <Style Selector="Grid.MainWindow">
        <Setter Property="Margin" Value="20 10" />
    </Style>
</Styles>