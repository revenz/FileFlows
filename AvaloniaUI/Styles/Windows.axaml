<Styles xmlns="https://github.com/avaloniaui">
    <!-- BASE BUTTON STYLE (Applies to all buttons) -->
    <Style Selector="Button">
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="FontWeight" Value="600"/>  
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="FontSize" Value="{DynamicResource BaseFontSize}" />
        <Setter Property="BorderThickness" Value="2"/>  
        <Setter Property="BorderBrush" Value="Transparent"/>  
        <Setter Property="Background" Value="{DynamicResource DefaultButtonBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource DefaultButtonForeground}" />
    </Style>
    
    <Style Selector="Button:not(.btnIcon)">
        <Setter Property="MinWidth" Value="120"/>
        <Setter Property="Margin" Value="4"/>  
    </Style>
    <Style Selector="Button.btnIcon">
        <Setter Property="MinWidth" Value="50"/>  
    </Style>

    <Style Selector="Button:focus">
        <Setter Property="Background" Value="{DynamicResource SystemAccentBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}" />
    </Style>

    <Style Selector="Button:pressed">
        <Setter Property="Background" Value="{DynamicResource DefaultButtonPressed}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}" />
    </Style>

    
    <!-- TextBox -->
    <Style Selector="TextBox">
        <Setter Property="Background" Value="{DynamicResource TextBoxBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBoxForeground}" />
        <Setter Property="CornerRadius" Value="6"/> <!-- Windows 11 Rounder Corners -->
        <Setter Property="Padding" Value="8,8"/>
        <Setter Property="FontSize" Value="{DynamicResource BaseFontSize}" />
        <Setter Property="BorderThickness" Value="2"/>  
        <Setter Property="BorderBrush" Value="{DynamicResource TextBoxBorder}" />
    </Style>

    <!-- Focused TextBox -->
    <Style Selector="TextBox:focus /template/ Border">
        <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}"/>
        <Setter Property="BorderThickness" Value="2"/> 
    </Style>

    <!-- Disabled TextBox -->
    <Style Selector="TextBox:disabled">
        <Setter Property="Background" Value="{DynamicResource DisabledBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource DisabledForeground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource DisabledBorder}" />
    </Style>

    
    
    <Style Selector="Window.messagebox" >
        <Setter Property="SystemDecorations" Value="Full" />
        <Setter Property="Padding" Value="10" />
        <Setter Property="SizeToContent" Value="WidthAndHeight" />
    </Style>
    <Style Selector="StackPanel.mbOuter">
        <Setter Property="Spacing" Value="10" />
    </Style>
    <Style Selector="StackPanel.mbContent TextBlock">
        <Setter Property="TextAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.mbTitle">
        <Setter Property="IsVisible" Value="False" />
    </Style>
    <Style Selector="StackPanel.modalButtons">
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>
    
</Styles>
