<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="FileFlows.AvaloniaUi.Controls.CardOption">
    
    <Border x:Name="RootBorder"
            BorderThickness="1" Margin="0,0,0,10"
            Background="Transparent"
            CornerRadius="8" Padding="10">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" VerticalAlignment="Center">
            <Image x:Name="Icon" Width="40" Height="40" Margin="0,10,20,0" VerticalAlignment="Center" />
            <StackPanel Orientation="Vertical" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                <TextBlock x:Name="TitleText" FontWeight="Bold" FontSize="16" />
                <TextBlock x:Name="DescriptionText" Margin="0,10,0,0" FontSize="12" Foreground="Gray" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>