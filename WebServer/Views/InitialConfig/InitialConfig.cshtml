                    </div>

                    <label class="toggle">
                        <input type="checkbox" role="switch" name="eula-accepted" id="eula-accepted"/>
                        <span id="eula-accept-label"></span>
                    </label>
                </div>
            </div>
        </div>

        @if (Model.Plugins.Count > 0)
        {
            <div class="page page-plugins">
                <div class="page-description" id="page-plugins-desc"></div>
                <div class="content">
                    <div class="flow-checklist">
                        @foreach (var item in Model.Plugins)
                        {
                            <label class="table-item">
                                <input type="checkbox" disabled="@item.ReadOnly"
                                       @(item.Checked ? "checked" : "")
                                       value="@item.Value"/>

                                <span class="icon">
                                    @{
                                        var icon = item.Icon?.EmptyAsNull() ?? "fas fa-puzzle-piece";
                                    }
                                    @if (icon.StartsWith("svg:"))
                                    {
                                        <img src="/icons/@(icon[4..]).svg"/>
                                    }
                                    else if (icon.StartsWith("data:") || icon.EndsWith(".svg") || icon.StartsWith('/') || icon.StartsWith("http:") || icon.StartsWith("https:"))
                                    {
                                        <img src="@icon"/>
                                    }
                                    else
                                    {
                                        var parts = icon.Split(':');
                                        if (parts.Length == 2)
                                        {
                                            <i class="icon @parts[0]" style="color:@parts[1]"></i>
                                        }
                                        else
                                        {
                                            <i class="icon @icon"></i>
                                        }
                                    }
                                </span>
                                <div class="center">
                                    <span class="name"><span class="name-actual" id="@(item.TranslationPrefix)-Label">@item.Name</span></span>
                                    <span class="description"><span id="@(item.TranslationPrefix)-Description">@item.Description</span></span>
                                </div>
                                @if (item.ReadOnly)
                                {
                                    <div class="right">
                                        <span class="top-right label-installed">Installed</span>
                                    </div>
                                }
                            </label>
                        }
                    </div>
                </div>
            </div>
        }

        @if (Model.DockerMods.Count > 0)
        {
            <div class="page page-dockermods">
                <div class="page-description" id="page-dockermods-desc"></div>
                <div class="content">
                    <div class="flow-checklist">
                        @foreach (var item in Model.DockerMods)
                        {
                            <label class="table-item">
                                <input type="checkbox" disabled="@item.ReadOnly"
                                       @(item.Checked ? "checked" : "")
                                       value="@item.Value"/>

                                <span class="icon">
                                    @{
                                        var icon = item.Icon?.EmptyAsNull() ?? "fas fa-puzzle-piece";
                                    }
                                    @if (icon.StartsWith("svg:"))
                                    {
                                        <img src="/icons/@(icon[4..]).svg"/>
                                    }
                                    else if (icon.StartsWith("data:") || icon.EndsWith(".svg") || icon.StartsWith('/') || icon.StartsWith("http:") || icon.StartsWith("https:"))
                                    {
                                        <img src="@icon"/>
                                    }
                                    else
                                    {
                                        var parts = icon.Split(':');
                                        if (parts.Length == 2)
                                        {
                                            <i class="icon @parts[0]" style="color:@parts[1]"></i>
                                        }
                                        else
                                        {
                                            <i class="icon @icon"></i>
                                        }
                                    }
                                </span>
                                <div class="center">
                                    <span class="name"><span class="name-actual" id="@(item.TranslationPrefix)-Name">@item.Name</span></span>
                                    <span class="description"><span id="@(item.TranslationPrefix)-Description">@item.Description</span></span>
                                </div>
                                @if (item.ReadOnly)
                                {
                                    <div class="right">
                                        <span class="top-right label-installed">Installed</span>
                                    </div>
                                }
                            </label>
                        }
                    </div>
                </div>
            </div>
        }

        <div class="page page-runners">
            <div class="page-description" id="page-runners-desc"></div>
            <div class="content">

                <div class="pre-text" id="runners-top">
                </div>

                <div class="runners">
                    <input id="number-of-runners" type="number" min="1" max="10" value="3" />
                </div>
            </div>
        </div>
        
        <div class="page page-finish">
            <div class="page-description" id="page-finish-desc"></div>
            <div class="content">

                <span id="finish-top"></span>

                <ol>
                    <li>
                        <span id="finish-create-first-flow"></span> 
                        <span id="finish-create-first-flow-desc"></span>
                    </li>
                    <li>
                        <span id="finish-create-first-library"></span>
                        <span id="finish-create-first-library-desc"></span>
                    </li>
                </ol>

                <span id="finish-bottom"></span>
            </div>
        </div>
        
        <div class="flow-wizard-navigation-buttons">
            <span class="previous hidden" id="btn-previous"></span>
            <span class="finish hidden" id="btn-finish"></span>
            <span class="next" id="btn-next"></span>
        </div>
    </div>
</div>


<div class="blocker" id="blocker">
    <div class="blocker-indicator">
        <div class="blocker-spinner">
        </div>
    </div>
</div>


<script>
    class InitialConfig {
        constructor() {
            this.activeTab = 0;
            this.saving = false;
            this.totalTabs = document.querySelectorAll('.flow-wizard-buttons .wizard-button').length;
            this.initializeTabs();
            this.initializeTranslations();
            
            // elements
            this.btnBottomPrevious = document.getElementById('btn-previous');
            this.btnBottomFinish = document.getElementById('btn-finish');
            this.btnBottomNext = document.getElementById('btn-next');
            
            this.selectTab(0);
            
            this.tabBtnWelcome = document.getElementById('button-welcome');
            this.tabBtnEula = document.getElementById('button-eula');
            this.tabBtnPlugins = document.getElementById('button-plugins');
            this.tabBtnDockerMods = document.getElementById('button-dockermods');
            this.tabBtnRunners = document.getElementById('button-runners');
            this.tabBtnFinish = document.getElementById('button-finish');
            
            this.btnWelcome = document.getElementById('button-welcome');
            this.lblWelcomeDescription = document.getElementById('page-welcome-desc');
            this.lblWelcomeContent = document.getElementById('page-welcome-content');
            
            this.btnEula = document.getElementById('button-eula');
            this.lblEulaDescription = document.getElementById('page-eula-desc');
            this.lblEulaAccpet = document.getElementById('eula-accept-label');
            this.chkEulaAccepted = document.getElementById('eula-accepted');
            
            this.btnPlugins = document.getElementById('button-plugins');
            this.lblPluginsDescription = document.getElementById('page-plugins-desc');
            
            this.btnDockerMods = document.getElementById('button-dockermods');
            this.lblDockerModsDescription = document.getElementById('page-dockermods-desc');
            
            this.btnRunners = document.getElementById('button-runners');
            this.lblRunnersDescription = document.getElementById('page-runners-desc');
            this.runnersTop = document.getElementById('runners-top');
            
            this.btnFinish = document.getElementById('button-finish');
            this.lblFinishDescription = document.getElementById('page-finish-desc');
            this.finishTop = document.getElementById('finish-top');
            this.finishBottom = document.getElementById('finish-bottom');
            this.finishFirstFlow = document.getElementById('finish-create-first-flow');
            this.finishFirstFlowDesc = document.getElementById('finish-create-first-flow-desc');
            this.finishFirstLibrary = document.getElementById('finish-create-first-library');
            this.finishFirstLibraryDesc = document.getElementById('finish-create-first-library-desc');
            
            this.initializeLanguage('en');

            this.btnBottomPrevious.addEventListener('click', () => {
                if (this.activeTab > 0)
                    this.selectTab(this.activeTab - 1);
            });
            this.btnBottomNext.addEventListener('click', () => {
                if (this.activeTab < this.totalTabs - 1)
                    this.selectTab(this.activeTab + 1);
            });

            this.btnBottomFinish.addEventListener('click', () => {
                this.submit();
            });
            
            this.chkEulaAccepted.addEventListener('change', () => {
                let checked = this.chkEulaAccepted.checked;
                if (this.tabBtnPlugins)
                    this.tabBtnPlugins.classList.remove('disabled');
                if (this.tabBtnDockerMods)
                    this.tabBtnDockerMods.classList.remove('disabled');
                this.tabBtnRunners.classList.remove('disabled');
                this.tabBtnFinish.classList.remove('disabled');
                if (checked === false)
                {
                    if (this.tabBtnPlugins)
                        this.tabBtnPlugins.classList.add('disabled');
                    if (this.tabBtnDockerMods)
                        this.tabBtnDockerMods.classList.add('disabled');
                    this.tabBtnRunners.classList.add('disabled');
                    this.tabBtnFinish.classList.add('disabled');                    
                }
            });
            
            this.btnLanguage = document.getElementById('lang-drop-down-button');
            this.languageDropDown = document.getElementById('language-dropdown');
            this.btnLanguage.addEventListener('click', () => {
                this.languageDropDown.style.display = 'block';
            });
            let langSelectedImg = this.btnLanguage.querySelector('.option-image');
            let langSelectedLabel = this.btnLanguage.querySelector('.option-label');
            this.languageDropDown.querySelectorAll('li').forEach((item) => {
                item.addEventListener('click', () => {
                    this.languageDropDown.style.display = 'none';
                    let langCode = item.getAttribute('data-value');
                    langSelectedLabel.innerText = item.querySelector('span').innerText;
                    langSelectedImg.src = `/icons/flags/${langCode}.svg`;
                    this.initializeLanguage(langCode);
                });
            });

            setTimeout(() => {
                this.setBlockState(false);             
            }, 250);
        }    
        
        setBlockState(state)
        {
            document.getElementById('blocker').style.display = state ? '' : 'none';
        }
        
        initializeLanguage(lang) {
            this.language = lang;
                        
            this.btnBottomPrevious.innerText = this.translations[lang].Previous;
            this.btnBottomFinish.innerText = this.translations[lang].Finish;
            this.btnBottomNext.innerText = this.translations[lang].Next;

            this.tabBtnWelcome.innerText = this.translations[lang].Welcome;
            this.tabBtnEula.innerText = this.translations[lang].Eula;

            if (this.tabBtnPlugins)
                this.tabBtnPlugins.innerText = this.translations[lang].Plugins;

            if (this.tabBtnDockerMods)
                this.tabBtnDockerMods.innerText = this.translations[lang].DockerMods;
            this.tabBtnRunners.innerText = this.translations[lang].Runners;
            this.tabBtnFinish.innerText = this.translations[lang].Finish;
            
            this.btnWelcome.innerText = this.translations[lang].Welcome;
            this.lblWelcomeDescription.innerText = this.translations[lang].WelcomeDescription;
            this.lblWelcomeContent.innerText = this.translations[lang].WelcomeMessage;
            
            this.btnEula.innerText = this.translations[lang].Eula;
            this.lblEulaDescription.innerText = this.translations[lang].EulaDescription;
            this.lblEulaAccpet.innerText = this.translations[lang].EulaAccept;

            if (this.tabBtnPlugins) {
                this.btnPlugins.innerText = this.translations[lang].Plugins;
                this.lblPluginsDescription.innerText = this.translations[lang].PluginsDescription;
            }

            if (this.tabBtnDockerMods)
                this.lblDockerModsDescription.innerText = this.translations[lang].DockerModsDescription;
            
            this.lblRunnersDescription.innerText = this.translations[lang].RunnersDescription;
            this.runnersTop.innerText = this.translations[lang].RunnersTop;
            
            this.btnFinish.innerText = this.translations[lang].Finish;
            this.lblFinishDescription.innerText = this.translations[lang].FinishDescription;
            this.finishTop.innerText = this.translations[lang].FinishTop;
            this.finishBottom.innerText = this.translations[lang].FinishBottom;
            this.finishFirstFlow.innerText = this.translations[lang].FinishCreateFirstFlow;
            this.finishFirstFlowDesc.innerText = this.translations[lang].FinishCreateFirstFlowDescription.replace(/\n/g, ' ');
            this.finishFirstLibrary.innerText = this.translations[lang].FinishCreateALibrary;
            this.finishFirstLibraryDesc.innerText = this.translations[lang].FinishCreateALibraryDescription.replace(/\n/g, ' ');

            let itemTranslations = this.translations[lang].ItemTranslations;
            Object.keys(itemTranslations).forEach((key) => {
                let ele = document.getElementById(key.replace('.', '-'));
                if (ele)
                    ele.innerText = itemTranslations[key];
            });
            
            for (let installedEle of document.querySelectorAll('.label-installed'))
                installedEle.innerText = this.translations[lang].Installed;
        }

        initializeTranslations()
        {
            this.translations = @Html.Raw(Json.Serialize(Model.Translations));
        }
        
        initializeTabs() {
            let buttons = document.querySelectorAll('.flow-wizard-buttons .wizard-button');            
            for (let i=0;i<buttons.length;i++) {
                let index = i;
                buttons[i].addEventListener('click', (event) => {
                    let target = event.target;
                    let eulaNeeded = target.getAttribute('data-eula-needed') === '1';
                    if(eulaNeeded && this.chkEulaAccepted.checked !== true)
                        return;
                    
                    this.selectTab(index);
                })
            }            
        }
        
        selectTab(index) {
            if (this.saving || (index > 1 && this.chkEulaAccepted.checked === false))
                return;
            
            this.activeTab = index;
            let contents = document.querySelectorAll('.flow-wizard-content .page');
            let buttons = document.querySelectorAll('.flow-wizard-buttons .wizard-button')
            for (let i=0;i<contents.length;i++)
            {
                contents[i].classList.remove('active');
                buttons[i].classList.remove('active');
                if (index === i)
                {
                    contents[i].classList.add('active');
                    buttons[i].classList.add('active');
                }
            }        
            if (this.activeTab === 0)
                this.btnBottomPrevious.classList.add('hidden');
            else
                this.btnBottomPrevious.classList.remove('hidden');
            
            if (this.activeTab === this.totalTabs - 1) {
                this.btnBottomNext.classList.add('hidden');
                this.btnBottomFinish.classList.remove('hidden');
            }
            else {
                this.btnBottomNext.classList.remove('hidden');
                this.btnBottomFinish.classList.add('hidden');
            }
        }
        
        async submit() {
            let model = {
                Language: this.language,
                Runners: document.getElementById('number-of-runners').value,
                Plugins: [],
                DockerMods: []
            };
            for (let chk of document.querySelectorAll('.page-plugins input:checked')){
                model.Plugins.push(chk.value);
            }
            for (let chk of document.querySelectorAll('.page-dockermods input:checked')){
                model.DockerMods.push(chk.value);
            }
            this.saving = true;
            this.setBlockState(true);

            try {
                let result = await fetch('/initial-config', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(model)
                });
                
                console.log('status code: ' + result.status);

                if (result.redirected) {
                    window.location.href = result.url; // Follow the redirect
                    return;
                }
                
                let responseBody = await result.text(); // Read response text
                Toast.error(responseBody || 'Failed to save configuration');
            } catch (error) {
                console.error('Error submitting form:', error);
                Toast.error('An error occurred while submitting the form.');
            }
            this.saving = false;
            this.setBlockState(false);
        }
            
    }
    
    new InitialConfig();
    
</script>

</body>
</html>