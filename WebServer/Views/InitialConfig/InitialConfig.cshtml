@model FileFlows.WebServer.Controllers.Pages.InitialConfigController.InitialConfigViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>FileFlows - Initial Configuration</title>
    <link rel="icon" type="image/svg" href="/favicon.svg" />
    <meta name="darkreader-lock">
    <link rel="stylesheet" href="/css/initial-config.css?v=@Globals.Version" />
    <link href="css/fontawesome/fontawesome.min.css?v=#VERSION#" rel="stylesheet" />
    <link href="css/fontawesome/all.min.css?v=#VERSION#" rel="stylesheet" />
    <script src="scripts/toast.js?v=#VERSION#"></script>
</head>
<body class="initial-config">

<div class="flow-wizard">
    <div class="flow-wizard-buttons">
        <span class="wizard-button active" data-eula-needed="0" id="button-welcome"></span>
        <span class="wizard-button" data-eula-needed="0" id="button-eula"></span>
        @if (Model.Plugins.Count > 0)
        {
            <span class="wizard-button disabled" data-eula-needed="1" id="button-plugins"></span>
        }
        @if (Model.DockerMods.Count > 0)
        {
            <span class="wizard-button disabled" data-eula-needed="1" id="button-dockermods"></span>
        }
        <span class="wizard-button disabled" data-eula-needed="1" id="button-runners"></span>
        <span class="wizard-button disabled" data-eula-needed="1" id="button-finish"></span>
    </div>
    <div class="flow-wizard-content">
        <div class="page page-welcome active">
            <div class="page-description" id="page-welcome-desc"></div>
            <div class="content">
                <div class="language-dropdown dropdown">
                    <button id="lang-drop-down-button" class="dropdown-button dd-btn">
                        <img src="/icons/flags/en.svg" class="option-image" />
                        <span id="selected-language-label" class="option-label">English</span>
                        <i class="fas fa-caret-down"></i>
                    </button>
                    <ul class="dropdown-menu" id="language-dropdown" style="display: none">
                        @foreach (var lang in Model.Languages)
                        {
                            <li data-value="@lang.Value">
                                <img src="@($"/icons/flags/{lang.Value}.svg")" class="option-image" />
                                <span>@lang.Label</span>
                            </li>
                        }
                    </ul>
                </div>
                <span id="page-welcome-content"></span>
            </div>
        </div>

        <div class="page page-eula">
            <div class="page-description" id="page-eula-desc"></div>
            <div class="content">
                <div class="page-eula-content">
                    <div class="eula">
