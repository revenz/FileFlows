@using FileFlows.Client.Components.Widgets
@using Humanizer

@namespace FileFlows.Client.Components

<div class="btn popup-panel-button" @onclick="TogglePopup">
    @Notifications.Count Notifications
</div>

<div class="popup-panel @(Visible ? "visible" : "") @(IsProcessing ? "is-processing" : "")">
    <div class="popup-panel-main">
        <RunnersComponent/>
        <div class="notifications">
            @foreach (var item in Notifications)
            {
                <div class="notification @item.Severity.ToString().Kebaberize()">
                    <span class="icon">
                        @switch (item.Severity)
                        {
                            case NotificationSeverity.Critical:
                                <i class="icon critical fas fa-exclamation-circle"></i>
                                break;
                            case NotificationSeverity.Error:
                                <i class="icon error fas fa-times-circle"></i>
                                break;
                            case NotificationSeverity.Warning:
                                <i class="icon warning fas fa-exclamation-triangle"></i>
                                break;
                            case NotificationSeverity.Information:
                                <i class="icon info fas fa-info-circle"></i>
                                break;
                        }
                    </span>
                    <div class="center">
                        <span class="title">@item.Title</span>
                        @if (string.IsNullOrWhiteSpace(item.Message) == false)
                        {
                            <span class="message">@item.Message</span>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
    <div class="popup-panel-bottom">
        <a  class="external-link"href="https://fileflows.com/"  title="FileFLows.com"  target="_blank" rel="noopener noreferrer nofollow">
            <i class="fas fa-globe"></i>
        </a>
        <a class="external-link" href="https://reddit.com/r/FileFlows" title="r/FileFlows" target="_blank" rel="noopener noreferrer nofollow">
            <i class="fab fa-reddit-alien"></i>
        </a>
        <a class="external-link" href="https://fileflows.com/discord" title="Discord" target="_blank" rel="noopener noreferrer nofollow">
            <i class="fab fa-discord"></i>
        </a>
        @if (ShowLogout || ShowChangePassword)
        {
            @if (ShowChangePassword)
            {
                <a class="user-link" title="@lblChangePassword" @onclick=ChangePassword>
                    <i class="fas fa-key"></i>
                </a>
            }
            @if (ShowLogout)
            {
                <a class="user-link" href="/logout" title="@lblLogout" @onclick=LogOut>
                    <i class="fas fa-unlock"></i>
                </a>
            }
        }
    </div>
</div>