@namespace FileFlows.Client.Components.Common
@typeparam TItem

<ul class="ul-radio-list">
    @foreach (var item in Items)
    {
        bool selected = item.Value.Equals(Value);
        
        <li @onclick="() => Select(item.Value)" class="clickable-radio @(selected ? "active" : "")"
            @ondblclick="() => DblClick(item.Value)">
            <span class="icon">
                <TableItemIcon Icon="@item.Icon" Unwrapped="true"/>
            </span>
            <div class="info">
                <span>@item.RenderTitle</span>
                <p>@item.RenderDescription</p>
            </div>
            @if (item.ChildContent != null)
            {
                <div class="options">
                    @item.ChildContent
                </div>
            }
        </li>
    }
</ul>

<CascadingValue IsFixed=true Value=this>
    @ChildContent
</CascadingValue>