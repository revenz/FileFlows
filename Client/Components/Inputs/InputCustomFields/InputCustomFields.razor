@namespace FileFlows.Client.Components.Inputs


@inherits Input<List<CustomField>>

<div class="wrapper">
    <FlowTable @ref="Table" Data="Value" NoFilter="true"
               TItem="CustomField" Selection="SelectionMode.Multiple" DoubleClick="@Edit" TableIdentifier="CustomFields"
    >
        <ToolBar>
            <FlowTableButton Clicked=AddField Icon="fas fa-plus" Label="Labels.Add" />
            <FlowTableButton Clicked=Edit SelectedOne="true" Icon="fas fa-edit" Label="Labels.Edit" />
            <FlowTableButton Clicked=Delete SelectedOneOrMore="true" Icon="fas fa-trash" Label="Labels.Delete" />
            <FlowTableButtonSeparator />
            <FlowTableButton Clicked=MoveUp Icon="fas fa-arrow-up" HideLabel="true" Label="Pages.AccessControl.Buttons.MoveUp" SelectedOneOrMore="true" />
            <FlowTableButton Clicked=MoveDown Icon="fas fa-arrow-down" HideLabel="true" Label="Pages.AccessControl.Buttons.MoveDown" SelectedOneOrMore="true" />
        </ToolBar>

        <Columns>
            <FlowTableColumn TItem="CustomField">
                <Header>
                    @Globals.lblName
                </Header>
                <Cell Context="item">
                    <span>@item.Name</span>
                </Cell>
            </FlowTableColumn>
        </Columns>
    </FlowTable>
</div>

<Editor @ref="CustomFieldEditor" />