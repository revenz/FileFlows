@namespace FileFlows.Client.Components.Editors

@inherits ModalEditor

<ModalEditorWrapper Modal="@this">
    
    <InputText @bind-Value="@Model.Name" Label="Label.Name" Validators="RequiredValidator" HideLabel="true" />
    <InputTextArea @bind-Value="@Model.Value" Label="Pages.Tag.Fields.Description"
                   HideLabel="true" Validators="RequiredValidator" FlexGrow="true" />

</ModalEditorWrapper>