@layout ConfigLayout

@page "/config/logging"
@inherits InputRegister
@namespace FileFlows.Client.Pages.Config.Configuration.Settings

<InputSwitch @bind-Value="@Model.LogQueueMessages" Label="Pages.Settings.Fields.LogQueueMessages"/>
@if (IsLicensed)
{
    <InputSwitch @bind-Value="@Model.LogEveryRequest" Label="Pages.Settings.Fields.LogEveryRequest" />
    <InputNumber @bind-Value="@Model.LogFileRetention" Label="Pages.Settings.Fields.LogFileRetention" Min=1 Max=100 />
}

<InputNumber @bind-Value="@Model.LibraryFileLogFileRetention" Label="Pages.Settings.Fields.LibraryFileLogFileRetention" Min=0 Max=10000 />

<FlowFormPageButtons IsSaving="@IsSaving" OnSave="@Save" HelpUrl="@HelpUrl" />